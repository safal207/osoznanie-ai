{
  "$defs": {
    "TrustLevel": {
      "enum": [
        "untrusted",
        "reported",
        "verified"
      ],
      "title": "TrustLevel",
      "type": "string"
    }
  },
  "$id": "https://osoznanie.ai/schemas/v0.1/evidence.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "access_policy": {
      "default": "owner-and-agent",
      "title": "Access Policy",
      "type": "string"
    },
    "captured_at": {
      "format": "date-time",
      "title": "Captured At",
      "type": "string"
    },
    "content_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content Hash"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "source_type": {
      "minLength": 1,
      "title": "Source Type",
      "type": "string"
    },
    "trust_level": {
      "$ref": "#/$defs/TrustLevel",
      "default": "reported"
    },
    "type": {
      "const": "evidence",
      "default": "evidence",
      "title": "Type",
      "type": "string"
    },
    "uri": {
      "minLength": 1,
      "title": "Uri",
      "type": "string"
    }
  },
  "required": [
    "source_type",
    "uri"
  ],
  "title": "Evidence",
  "type": "object",
  "x-osoznanie-protocol-version": "0.1"
}
